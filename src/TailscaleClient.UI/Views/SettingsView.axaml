<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TailscaleClient.UI.ViewModels"
             xmlns:svc="using:TailscaleClient.UI.Services"
             x:Class="TailscaleClient.UI.Views.SettingsView"
             x:DataType="vm:MainViewModel">
    <ScrollViewer>
        <StackPanel>
            <Border Classes="card" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="Network" Margin="0,0,0,8" />

                    <CheckBox Margin="0,4" Content="Use Tailscale DNS (MagicDNS)"
                              IsChecked="{Binding Service.AcceptDns, Mode=OneWay}"
                              Click="AcceptDns_Click" />
                    <TextBlock Classes="muted" Margin="26,0,0,8"
                               Text="Resolve devices by name and use the tailnet's configured DNS." />

                    <CheckBox Margin="0,4" Content="Accept subnet routes"
                              IsChecked="{Binding Service.AcceptRoutes, Mode=OneWay}"
                              Click="AcceptRoutes_Click" />
                    <TextBlock Classes="muted" Margin="26,0,0,8"
                               Text="Route traffic for subnets advertised by other peers." />

                    <CheckBox Margin="0,4" Content="Block incoming connections (shields up)"
                              IsChecked="{Binding Service.ShieldsUp, Mode=OneWay}"
                              Click="ShieldsUp_Click" />
                    <TextBlock Classes="muted" Margin="26,0,0,8"
                               Text="Drop all unsolicited inbound traffic from your tailnet." />

                    <CheckBox Margin="0,4" Content="Run Tailscale SSH server"
                              IsChecked="{Binding Service.RunSsh, Mode=OneWay}"
                              Click="RunSsh_Click" />
                    <TextBlock Classes="muted" Margin="26,0,0,8"
                               Text="Allow other tailnet users with the right ACL to SSH into this machine." />
                </StackPanel>
            </Border>

            <Border Classes="card" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="Advertise subnet routes" Margin="0,0,0,8" />
                    <TextBlock Foreground="#6B7280" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="Add a CIDR (or comma-separated list). Subnet routing must also be approved in the admin console." />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="RoutesBox" Grid.Column="0" Padding="8,6" Margin="0,0,8,0"
                                 PlaceholderText="e.g. 192.168.1.0/24" KeyDown="RoutesBox_KeyDown" />
                        <Button Grid.Column="1" Classes="primary" Content="Add" Click="AddRoutes_Click" />
                    </Grid>
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Classes="muted" Text="Current:" />
                        <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding Service.AdvertisedRoutes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                            CornerRadius="3" Padding="8,2" Margin="0,0,6,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                                       Foreground="#1E40AF"
                                                       Text="{Binding}" />
                                            <Button Classes="tiny" Margin="6,0,0,0" Padding="6,0"
                                                    MinWidth="0" Background="Transparent" Foreground="#6B7280"
                                                    ToolTip.Tip="Remove"
                                                    Content="×" Click="RemoveRoute_Click" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Classes="muted" Margin="0,14,0,4" Text="Local network adapters:" />
                    <ItemsControl x:Name="LocalCidrsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="svc:LocalCidr">
                                <Grid ColumnDefinitions="180,*,Auto" Margin="0,2">
                                    <TextBlock Grid.Column="0" Classes="muted" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding InterfaceName}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                                               Text="{Binding Cidr}" />
                                    <Button Grid.Column="2" Classes="secondary" Padding="10,2"
                                            Content="Add" Click="AddLocalCidr_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Classes="card" Padding="16">
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="Account" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#6B7280" Text="Logged in as: " />
                        <TextBlock Foreground="#6B7280" Text="{Binding Service.Self.DNSName, FallbackValue='—'}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                        <TextBlock Foreground="#6B7280" Text="Tailnet: " />
                        <TextBlock Foreground="#6B7280" Text="{Binding Service.TailnetName, FallbackValue='—'}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Classes="secondary" Content="Sign in again" Command="{Binding LoginCommand}" />
                        <Button Classes="danger" Content="Log out" Command="{Binding LogoutCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
