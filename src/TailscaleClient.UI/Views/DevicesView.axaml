<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TailscaleClient.UI.ViewModels"
             xmlns:m="using:TailscaleClient.Core.Models"
             x:Class="TailscaleClient.UI.Views.DevicesView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- This machine -->
        <Border Grid.Row="0" Classes="card" Padding="14" Margin="0,0,0,12">
            <StackPanel DataContext="{Binding Service.Self}">
                <TextBlock Classes="section" Text="This machine" Margin="0,0,0,4" />
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="15" FontWeight="SemiBold"
                                   Text="{Binding ((m:PeerStatus)DataContext).DisplayName, FallbackValue='—', RelativeSource={RelativeSource Self}}" />
                        <TextBlock Foreground="#6B7280"
                                   Text="{Binding ((m:PeerStatus)DataContext).TailscaleIPs, RelativeSource={RelativeSource Self}, Converter={StaticResource IpList}}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="secondary" Content="Copy IP"
                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CopyIpCommand}"
                            CommandParameter="{Binding ((m:PeerStatus)DataContext).TailscaleIPs, RelativeSource={RelativeSource Self}, Converter={StaticResource FirstOrEmpty}}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Peers list -->
        <Border Grid.Row="1" Classes="card">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="40,*,180,120,210">
                        <TextBlock Grid.Column="1" Classes="section" Text="Device" Margin="0" />
                        <TextBlock Grid.Column="2" Classes="section" Text="Tailscale IP" Margin="0" />
                        <TextBlock Grid.Column="3" Classes="section" Text="Status" Margin="0" />
                        <TextBlock Grid.Column="4" Classes="section" Text="Actions" Margin="0" />
                    </Grid>
                </Border>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Service.SortedPeers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:PeerStatus">
                                <Border Padding="14,10" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="40,*,180,120,210">
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                                 Fill="{Binding Online, Converter={StaticResource OnlineToBrush}}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Classes="muted" Text="{Binding OS}" />
                                                <TextBlock Classes="muted" Text=" · " />
                                                <TextBlock Classes="muted" Text="{Binding HostName}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                                                   Text="{Binding TailscaleIPs, Converter={StaticResource IpList}}" />
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="#6B7280"
                                                   Text="{Binding ., Converter={StaticResource OnlineToLastSeen}}" />
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Classes="secondary tiny" Content="Copy"
                                                    ToolTip.Tip="Copy first Tailscale IP"
                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CopyIpCommand}"
                                                    CommandParameter="{Binding TailscaleIPs, Converter={StaticResource FirstOrEmpty}}" />
                                            <Button Classes="secondary tiny" Content="Ping"
                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).PingPeerCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Classes="secondary tiny" Content="Send file"
                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SendFileToCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
