<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TailscaleClient.UI.ViewModels"
             xmlns:m="using:TailscaleClient.Core.Models"
             x:Class="TailscaleClient.UI.Views.DevicesView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- This machine -->
        <Border Grid.Row="0" Classes="card" Padding="14" Margin="0,0,0,12">
            <StackPanel DataContext="{Binding Service.Self}">
                <TextBlock Classes="section" Text="This machine" Margin="0,0,0,4" />
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               ToolTip.Tip="Double-click to copy"
                               DoubleTapped="OnCopyTextDoubleTapped"
                               Text="{Binding ((m:PeerStatus)DataContext).ShortName, FallbackValue='—', RelativeSource={RelativeSource Self}}" />
                    <TextBlock Foreground="#6B7280"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               ToolTip.Tip="Double-click to copy"
                               DoubleTapped="OnCopyTextDoubleTapped"
                               Text="{Binding ((m:PeerStatus)DataContext).DisplayName, FallbackValue='', RelativeSource={RelativeSource Self}}" />
                    <TextBlock Foreground="#6B7280"
                               FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                               Cursor="Hand"
                               ToolTip.Tip="Double-click to copy IPv4"
                               DoubleTapped="OnCopyTextDoubleTapped"
                               IsVisible="{Binding ((m:PeerStatus)DataContext).IPv4, RelativeSource={RelativeSource Self}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Text="{Binding ((m:PeerStatus)DataContext).IPv4, FallbackValue='', RelativeSource={RelativeSource Self}}" />
                    <TextBlock Foreground="#6B7280"
                               FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                               Cursor="Hand"
                               ToolTip.Tip="Double-click to copy IPv6"
                               DoubleTapped="OnCopyTextDoubleTapped"
                               IsVisible="{Binding ((m:PeerStatus)DataContext).IPv6, RelativeSource={RelativeSource Self}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Text="{Binding ((m:PeerStatus)DataContext).IPv6, FallbackValue='', RelativeSource={RelativeSource Self}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Peers — DataGrid with resizable columns -->
        <Border Grid.Row="1" Classes="card" ClipToBounds="True">
            <DataGrid x:Name="PeersGrid"
                      ItemsSource="{Binding Service.SortedPeers}"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      Background="Transparent"
                      RowBackground="Transparent"
                      DoubleTapped="OnDataGridDoubleTapped">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Device" Width="*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="m:PeerStatus">
                                <StackPanel VerticalAlignment="Center" Margin="10,6">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ShortName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Classes="muted" Text="{Binding OS}" />
                                        <TextBlock Classes="muted" Text=" · " />
                                        <TextBlock Classes="muted" Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Tailscale IP" Width="220" MinWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="m:PeerStatus">
                                <StackPanel VerticalAlignment="Center" Margin="10,6">
                                    <TextBlock FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Cursor="Hand"
                                               ToolTip.Tip="Double-click to copy IPv4"
                                               DoubleTapped="OnCopyTextDoubleTapped"
                                               IsVisible="{Binding IPv4, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Text="{Binding IPv4}" />
                                    <TextBlock FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12"
                                               Foreground="#6B7280"
                                               TextTrimming="CharacterEllipsis"
                                               Cursor="Hand"
                                               ToolTip.Tip="Double-click to copy IPv6"
                                               DoubleTapped="OnCopyTextDoubleTapped"
                                               IsVisible="{Binding IPv6, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Text="{Binding IPv6}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="120" MinWidth="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="m:PeerStatus">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,6">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Fill="{Binding Online, Converter={StaticResource OnlineToBrush}}" />
                                    <TextBlock VerticalAlignment="Center" Foreground="#6B7280"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding ., Converter={StaticResource OnlineToLastSeen}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Actions" Width="Auto" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="m:PeerStatus">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,4">
                                    <Button Classes="secondary tiny" Content="Ping"
                                            IsEnabled="{Binding Online}"
                                            ToolTip.Tip="Offline — cannot ping"
                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).PingPeerCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Classes="secondary tiny" Content="Send file"
                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SendFileToCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
