<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:TailscaleClient.UI.Converters"
             x:Class="TailscaleClient.UI.App"
             RequestedThemeVariant="Light">

    <Application.Styles>
        <FluentTheme />

        <!-- Buttons -->
        <Style Selector="Button.primary">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2563EB" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#9CA3AF" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D1D5DB" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B91C1C" />
        </Style>

        <Style Selector="Button.tiny">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <conv:BackendStateToColorConverter x:Key="StateToColor" />
            <conv:BackendStateToTextConverter x:Key="StateToText" />
            <conv:BooleanInverter x:Key="Invert" />
            <conv:IpListConverter x:Key="IpList" />
            <conv:RelativeTimeConverter x:Key="RelativeTime" />
            <conv:BytesToHumanConverter x:Key="HumanBytes" />
            <conv:OnlineToBrushConverter x:Key="OnlineToBrush" />
            <conv:OnlineToLastSeenConverter x:Key="OnlineToLastSeen" />
            <conv:FirstOrEmptyConverter x:Key="FirstOrEmpty" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
